# Environment variables template for Cloud Resilience Visualizer.
# Copy this file to .env and fill in real values.
# DO NOT commit your real .env — it is gitignored.

# Application environment
APP_ENV=development

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === AWS settings (uncomment when connecting to a live AWS account) ===
# Preferred: configure the AWS Command Line Interface ('aws configure')
# and let boto3 pick up credentials automatically.
# The lines below are only for when you must inject credentials explicitly.
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-here